# ---- Model gateway (LiteLLM) ----
# Any OpenAI-compatible provider works. Examples below; fill what you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional: point LiteLLM at a custom/self-hosted (e.g. vLLM) OpenAI-compatible base URL.
# OPENAI_API_BASE=http://localhost:8000/v1

# Default model the orchestrator/worker/finalizer use (LiteLLM model string).
RIPTIDE_WATERGRAPH_MODEL=gpt-4o-mini

# ---- Observability (Langfuse, OTEL-native v3) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional generic OTEL exporter (if not using Langfuse's own ingestion).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Set to 1 to disable all tracing (useful for offline/CI runs).
RIPTIDE_WATERGRAPH_DISABLE_TRACING=0
